/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-src https://tally.so https://*.tally.so; connect-src 'self' https:; font-src 'self' data:; base-uri 'self'; form-action 'self' https://tally.so https://*.tally.so; frame-ancestors 'self'
