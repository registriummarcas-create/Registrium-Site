---
import BaseLayout from './BaseLayout.astro';

export interface TocItem {
  href: string;
  label: string;
}

export interface RelatedPost {
  href: string;
  tag: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  pill: string;
  heroTitle: string;
  heroDescription: string;
  meta: string[];
  backHref: string;
  backLabel: string;
  toc: TocItem[];
  related: RelatedPost[];
}

const { title, description, pill, heroTitle, heroDescription, meta, backHref, backLabel, toc, related } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <header class="blog-hero">
    <img class="blog-hero-watermark" src="/images/logo-mark.png" alt="" aria-hidden="true" />
    <div class="container">
      <a class="back" href={backHref}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {backLabel}
      </a>
      <span class="pill">
        <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z" fill="currentColor"/></svg>
        {pill}
      </span>
      <h1>{heroTitle}</h1>
      <p>{heroDescription}</p>
      <div class="blog-meta">
        {meta.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </header>

  <section class="section article">
    <div class="container article-layout">
      <nav class="toc reveal">
        <div class="tk">Neste artigo</div>
        {toc.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <div class="article-content">
        <slot />
        <div class="blog-cta reveal">
          <h3>Pronto para começar o registro da sua marca?</h3>
          <p>Preencha o cadastro prévio e continue a conversa direto no WhatsApp com a Registrium.</p>
          <a class="button button--secondary" href="/#cadastro">
            Ir para o cadastro
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft related">
    <div class="container">
      <div class="section-title reveal"><p class="eyebrow">Continue lendo</p><h2>Outras publicações</h2></div>
      <div class="related-grid reveal">
        {related.map((post) => (
          <a class="related-card" href={post.href}>
            <span class="rc-tag">{post.tag}</span>
            <h4>{post.title}</h4>
            <p>{post.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<style>
.blog-hero { position: relative; overflow: hidden; background:
    radial-gradient(120% 90% at 85% 20%, rgba(70,110,230,.26), transparent 55%),
    radial-gradient(90% 80% at 10% 90%, rgba(120,70,200,.22), transparent 60%),
    linear-gradient(125deg, var(--color-navy-950) 0%, var(--color-indigo-900) 55%, var(--color-purple-900) 100%);
  padding: 4.5rem 0 3.5rem; color: var(--color-white); }
.blog-hero-watermark { position: absolute; z-index: 0; top: 50%; right: -4rem; transform: translateY(-50%); width: 22rem; max-width: 45%; opacity: .06; pointer-events: none; user-select: none; }
.blog-hero .container { position: relative; z-index: 1; }
.blog-hero .back { display: inline-flex; align-items: center; gap: .5rem; color: var(--color-on-dark); text-decoration: none; font-size: .84rem; font-weight: 600; font-family: 'Plus Jakarta Sans', sans-serif; margin-bottom: 1.375rem; }
.blog-hero .back:hover { color: var(--color-white); }
.blog-hero .pill { display: inline-flex; align-items: center; gap: .55rem; border: 1px solid rgba(255,255,255,.22); background: rgba(255,255,255,.06); color: var(--color-white); border-radius: 999px; padding: .55rem 1.05rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .75rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
.blog-hero .pill svg { width: .95rem; height: .95rem; color: #8fd0f5; }
.blog-hero h1 { color: var(--color-white); font-size: clamp(1.875rem, 4.4vw, 3rem); font-weight: 800; line-height: 1.1; max-width: 47.5rem; margin-top: 1.375rem; }
.blog-hero p { color: var(--color-on-dark); font-size: 1.03rem; line-height: 1.6; max-width: 38.75rem; margin-top: 1.125rem; }
.blog-meta { display: flex; gap: 1.125rem; flex-wrap: wrap; margin-top: 1.625rem; }
.blog-meta span { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .75rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-on-dark-soft); border: 1px solid rgba(255,255,255,.18); border-radius: 999px; padding: .44rem .875rem; }

.article-layout { display: grid; grid-template-columns: 13.75rem 1fr; gap: 3rem; align-items: start; min-width: 0; }
.article-layout > * { min-width: 0; }
.toc { position: sticky; top: 5.5rem; display: flex; flex-direction: column; gap: .625rem; }
.toc .tk { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .69rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--color-muted); margin-bottom: .25rem; }
.toc a { font-size: .84rem; color: var(--color-muted); text-decoration: none; padding: .375rem 0; border-left: 2px solid var(--color-border); padding-left: .875rem; transition: color .15s ease, border-color .15s ease; }
.toc a:hover { color: var(--color-violet); border-color: var(--color-violet); }

.related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 60rem; margin: 0 auto; }
.related-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: 1rem; padding: 1.375rem; text-decoration: none; transition: transform .16s ease, box-shadow .16s ease; }
.related-card:hover { transform: translateY(-3px); box-shadow: 0 20px 36px -26px rgba(30,20,80,.4); }
.related-card .rc-tag { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .66rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-violet); margin-bottom: .625rem; display: block; }
.related-card h4 { font-size: .97rem; font-weight: 700; color: var(--color-text); margin: 0 0 .5rem; line-height: 1.3; }
.related-card p { font-size: .81rem; color: var(--color-muted); margin: 0; line-height: 1.5; }

@media (max-width: 920px) { .article-layout { grid-template-columns: 1fr; } .toc { position: static; flex-direction: row; flex-wrap: wrap; gap: .5rem 1rem; margin-bottom: .75rem; } .toc .tk { width: 100%; } .related-grid { grid-template-columns: 1fr; } }
@media (max-width: 560px) { .blog-hero { padding: 3.25rem 0 2.5rem; } }
</style>
