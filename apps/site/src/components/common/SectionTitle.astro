---
interface Props { eyebrow?: string; title: string; description?: string; }
const { eyebrow, title, description } = Astro.props;
---
<div class="section-title">
  {eyebrow && <p class="eyebrow"><span class="brand-chip"><img src="/images/logo-mark.png" alt="" aria-hidden="true" /></span>{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</div>
