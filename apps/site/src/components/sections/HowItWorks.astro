---
const steps = [
  {
    icon: '<path d="M4 5h16v11H9l-3.5 3.5V16H4z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8 9h8M8 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    label: 'Etapa 01',
    title: 'Você conta o nome.',
    description: 'Cadastro em dois minutos. Só o essencial, sem formulário quilométrico.'
  },
  {
    icon: '<circle cx="11" cy="11" r="6" stroke="currentColor" stroke-width="1.8"/><path d="M20 20l-4.2-4.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
    label: 'Etapa 02',
    title: 'A gente procura e faz o estudo de viabilidade.',
    description: 'Busca minuciosamente no banco do INPI com software com IA, identificamos os riscos e oportunidades. Você decide com a informação na mão.'
  },
  {
    icon: '<path d="M7 3h7l4 4v14H7z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 13l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
    label: 'Etapa 03',
    title: 'A gente protocola.',
    description: 'Em até 48h após a contratação, nós entregamos o protocolo. Após realizar a classificação de Nice e adequar a logomarca.'
  },
  {
    icon: '<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="12" cy="12" r="2.6" stroke="currentColor" stroke-width="1.8"/>',
    label: 'Etapa 04',
    title: 'A gente não solta tua mão.',
    description: 'Acompanhamento de perto e com software de última geração, todos os prazos e monitoramento da RPI até a decisão. E depois dela também.'
  },
  {
    icon: '<path d="M12 3v18M6 21h12M12 6l6 3-2.5 4.5a3.8 3.8 0 01-7 0L6 9l6-3z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>',
    label: 'Etapa 05',
    title: 'A gente te entrega o resultado.',
    description: 'Defendemos sua marca em oposições, respondemos às exigências do INPI dentro do prazo e acompanhamos até a emissão do certificado, válido por 10 anos. Sem cobrança nova a cada movimentação.'
  }
];
---
<section id="como-funciona" class="section process">
  <div class="proc-glow" aria-hidden="true"></div>
  <div class="container proc-grid">
    <div class="reveal proc-intro">
      <span class="eyebrow" style="color:var(--color-cyan);"><span class="brand-chip"><img src="/images/logo-mark.png" alt="" aria-hidden="true" /></span>Como funciona</span>
      <h2>Um processo claro, do início ao certificado</h2>
      <p>Você acompanha cada etapa do conforto da sua empresa, sem burocracia e sem cobranças a cada movimento processual.</p>
    </div>
    <div class="timeline">
      {steps.map((step, i) => (
        <div class="tl-item reveal" style={`transition-delay:${i * 60}ms`}>
          <div class="tl-marker">
            <div class="icon-tile tl-icon"><svg viewBox="0 0 24 24" fill="none" set:html={step.icon} /></div>
          </div>
          <div class="tl-content">
            <div class="etapa">{step.label}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
.process { position: relative; overflow: hidden; }
.proc-glow { position: absolute; z-index: 0; top: -6rem; right: -10rem; width: 44rem; max-width: 120%; aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgba(62,111,230,.09), transparent 70%); pointer-events: none; animation: driftB 24s ease-in-out infinite; }
.process .container { position: relative; z-index: 1; }
.proc-grid { display: grid; grid-template-columns: .85fr 1.15fr; gap: 3.25rem; align-items: start; }
.proc-intro { position: sticky; top: calc(var(--header-height) + 2rem); }
.process h2 { font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 800; margin-top: .75rem; line-height: 1.12; }
.process p { color: var(--color-muted); font-size: .97rem; margin-top: .875rem; line-height: 1.55; max-width: 24rem; }
.timeline { display: flex; flex-direction: column; }
.tl-item { display: flex; gap: 1.125rem; position: relative; padding-bottom: 1.625rem; }
.tl-item:last-child { padding-bottom: 0; }
.tl-marker { position: relative; flex: none; }
.tl-marker::after { content: ""; position: absolute; top: 2.6rem; bottom: -1.625rem; left: 50%; width: 2px; transform: translateX(-50%); background: linear-gradient(var(--color-border), var(--color-border)); }
.tl-item:last-child .tl-marker::after { display: none; }
.tl-icon { width: 2.6rem; height: 2.6rem; border-radius: .75rem; transition: transform .2s ease; }
.tl-icon svg { width: 1.2rem; height: 1.2rem; }
.tl-item:hover .tl-icon { transform: scale(1.08) rotate(-4deg); }
.tl-content { padding-top: .15rem; }
.tl-content .etapa { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--color-muted); }
.tl-content h3 { font-size: 1.06rem; margin: .2rem 0 .3rem; }
.tl-content p { color: var(--color-muted); font-size: .87rem; line-height: 1.5; margin: 0; max-width: 30rem; }
@media (max-width: 800px) { .proc-grid { grid-template-columns: 1fr; gap: 2rem; } .proc-intro { position: static; } }
</style>
