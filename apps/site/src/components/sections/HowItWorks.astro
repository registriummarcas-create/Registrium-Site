---
const steps = [
  {
    icon: '<path d="M4 5h16v11H9l-3.5 3.5V16H4z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8 9h8M8 12h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>',
    label: 'Etapa 01',
    title: 'Você conta o nome.',
    description: 'Cadastro em dois minutos. Só o essencial, sem formulário quilométrico.'
  },
  {
    icon: '<circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.6"/><path d="M14.8 14.8 20.5 20.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/>',
    label: 'Etapa 02',
    title: 'A gente procura e faz o estudo de viabilidade.',
    description: 'Realizamos uma busca minuciosa no banco de dados do INPI, apoiada por software com inteligência artificial, para identificar riscos, colidências e oportunidades. Você decide com a informação em mãos.'
  },
  {
    icon: '<path d="M6 3h9l4 4v14H6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/><path d="M15 3v4h4" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/><path d="M9 13h7M9 17h7" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/>',
    label: 'Etapa 03',
    title: 'A gente protocola.',
    description: 'Após definir a classificação de Nice e realizar os ajustes necessários na apresentação da marca, protocolamos o pedido em até 48h após a contratação.'
  },
  {
    icon: '<circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"/><path d="M12 12 17 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/><circle cx="12" cy="12" r="1.3" fill="currentColor"/>',
    label: 'Etapa 04',
    title: 'A gente não solta sua mão.',
    description: 'Acompanhamento de perto e com software com inteligência artificial, todos os prazos e monitoramento da RPI até a decisão. E depois dela também.'
  },
  {
    icon: '<path d="M6 3h12v13H6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/><path d="M9 20 12 17l3 3v-7H9z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/>',
    label: 'Etapa 05',
    title: 'A gente te entrega o resultado.',
    description: 'Defendemos sua marca em oposições, respondemos às exigências do INPI dentro do prazo e acompanhamos até a emissão do certificado, válido por 10 anos. Sem cobrança nova a cada movimentação.'
  }
];
---
<section id="como-funciona" class="section process">
  <div class="proc-glow" aria-hidden="true"></div>
  <div class="container proc-grid">
    <div class="reveal proc-intro">
      <span class="eyebrow" style="color:var(--color-blue);"><span class="chapter-mark"><span class="chapter-num">06</span><span class="chapter-dash">—</span></span><span class="brand-chip"><img src="/images/logo-mark.png" alt="" aria-hidden="true" loading="lazy" /></span>Como funciona</span>
      <h2>Um processo claro, do início ao certificado</h2>
      <p>Você acompanha cada etapa do conforto da sua empresa, sem burocracia e sem cobranças a cada movimento processual.</p>
      <div class="tech-demo" aria-hidden="true">
        <div class="tech-demo-head">
          <span class="process-tag tech-demo-tag">Representação ilustrativa</span>
        </div>
        <div class="tech-demo-query">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.6"/><path d="M14.8 14.8 20.5 20.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/></svg>
          <span class="tech-demo-brand">Nuvia Café</span>
          <span class="tech-demo-class">Classe 43 · Nice</span>
        </div>
        <div class="tech-demo-results">
          <div class="tech-demo-row">
            <span class="tech-demo-name">Núvia Cafés</span>
            <span class="tech-demo-badge tech-demo-badge--warn">Colisão fonética</span>
          </div>
          <div class="tech-demo-row">
            <span class="tech-demo-name">Nuvia Moda</span>
            <span class="tech-demo-badge tech-demo-badge--ok">Classe distinta</span>
          </div>
        </div>
        <div class="tech-demo-foot">Busca de anterioridade · colisão fonética e gráfica · risco estimado por classe</div>
      </div>
    </div>
    <div class="timeline">
      {steps.map((step, i) => (
        <div class="tl-item reveal" style={`transition-delay:${i * 60}ms`}>
          <div class="tl-marker">
            <div class="icon-tile tl-icon"><svg viewBox="0 0 24 24" fill="none" set:html={step.icon} /></div>
          </div>
          <div class="tl-content">
            <div class="etapa">{step.label}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
.process { position: relative; overflow: hidden; }
.chapter-mark { display: inline-flex; align-items: center; gap: .3rem; flex: none; }
.chapter-num { font-family: var(--font-mono); font-weight: 700; }
.chapter-dash { opacity: .75; }
.proc-glow { position: absolute; z-index: 0; top: -6rem; right: -10rem; width: 44rem; max-width: 120%; aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgba(62,111,230,.09), transparent 70%); pointer-events: none; animation: driftB 24s ease-in-out infinite; }
.process .container { position: relative; z-index: 1; }
.proc-grid { display: grid; grid-template-columns: .85fr 1.15fr; gap: 3.25rem; align-items: start; }
.proc-intro { position: sticky; top: calc(var(--header-height) + 2rem); }
.process h2 { font-size: clamp(1.75rem, 3.2vw, 2.5rem); font-weight: 700; margin-top: .75rem; line-height: 1.1; }
.process p { color: var(--color-muted); font-size: .97rem; margin-top: .875rem; line-height: 1.55; max-width: 24rem; }

.tech-demo { margin-top: 1.75rem; max-width: 24rem; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); }
.tech-demo-head { display: flex; justify-content: flex-end; padding: .55rem .875rem; background: var(--color-cream); border-bottom: 1px solid var(--color-border); }
.tech-demo-tag { color: var(--color-muted); border-color: var(--color-border); opacity: .75; }
.tech-demo-query { display: flex; align-items: center; gap: .625rem; padding: 1rem 1.125rem .75rem; }
.tech-demo-query svg { color: var(--color-violet); flex: none; animation: techPulse 4s ease-in-out infinite; }
@keyframes techPulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.12); opacity: .75; } }
.tech-demo-brand { font-family: var(--font-ui); font-weight: 800; font-size: 1rem; color: var(--color-text); }
.tech-demo-class { margin-left: auto; font-family: var(--font-mono); font-size: .64rem; color: var(--color-muted); border: 1px solid var(--color-border); border-radius: .3rem; padding: .18rem .45rem; white-space: nowrap; }
.tech-demo-results { padding: .25rem 1.125rem 1rem; display: flex; flex-direction: column; gap: .5rem; }
.tech-demo-row { display: flex; align-items: center; justify-content: space-between; gap: .75rem; padding: .55rem .75rem; background: var(--color-cream); border-radius: .55rem; }
.tech-demo-name { font-size: .85rem; font-weight: 600; color: var(--color-text); }
.tech-demo-badge { flex: none; font-family: var(--font-mono); font-size: .6rem; font-weight: 700; padding: .2rem .5rem; border-radius: .3rem; white-space: nowrap; }
.tech-demo-badge--warn { color: #6b5300; background: rgba(255,204,41,.22); }
.tech-demo-badge--ok { color: var(--color-good); background: rgba(31,122,77,.12); }
.tech-demo-foot { padding: .75rem 1.125rem; border-top: 1px solid var(--color-border); font-size: .68rem; color: var(--color-muted); line-height: 1.5; }
.timeline { display: flex; flex-direction: column; }
.tl-item { display: flex; gap: 1.125rem; position: relative; padding-bottom: 1.625rem; }
.tl-item:last-child { padding-bottom: 0; }
.tl-marker { position: relative; flex: none; }
.tl-marker::after { content: ""; position: absolute; top: 2.6rem; bottom: -1.625rem; left: 50%; width: 2px; transform: translateX(-50%); background: linear-gradient(var(--color-border), var(--color-border)); }
.tl-item:last-child .tl-marker::after { display: none; }
.tl-icon { width: 2.6rem; height: 2.6rem; border-radius: .75rem; transition: transform .2s ease; }
.tl-icon svg { width: 1.2rem; height: 1.2rem; }
.tl-item:hover .tl-icon { transform: scale(1.08) rotate(-4deg); }
.tl-content { padding-top: .15rem; }
.tl-content .etapa { font-family: var(--font-mono); font-size: .68rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--color-violet); }
.tl-content h3 { font-size: 1.06rem; margin: .2rem 0 .3rem; }
.tl-content p { color: var(--color-muted); font-size: .87rem; line-height: 1.5; margin: 0; max-width: 30rem; }
@media (max-width: 800px) { .proc-grid { grid-template-columns: 1fr; gap: 2rem; } .proc-intro { position: static; } }
</style>
