---
import fallback from '../../data/instagram-fallback.json';
import { contactConfig } from '../../config/contact';
---
<section class="section ig-embed">
  <div class="container">
    <p class="eyebrow ig-embed-eyebrow"><span class="chapter-mark"><span class="chapter-num">02</span><span class="chapter-dash">—</span></span><span class="brand-chip"><img src="/images/logo-mark.png" alt="" aria-hidden="true" loading="lazy" /></span>Instagram</p>

    <!-- Widget da Elfsight (posts reais ao vivo) -->
    <div class="ig-elfsight" id="igElfsight">
      <!-- Elfsight Instagram Feed | Untitled Instagram Feed -->
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-849d22e6-3467-4295-a6b7-158a4b2f0703"></div>
    </div>

    <!-- Rede de segurança: seção nativa exibida se o widget não renderizar -->
    <div class="ig-fallback" id="igFallback" hidden>
      <div class="ig-head">
        <div class="ig-profile">
          <div class="ig-avatar"><div><img src="/images/logo-mark.png" alt="Registrium" /></div></div>
          <div><div class="handle">{contactConfig.instagramHandle}</div><div class="name">Registrium · Copyright e Marcas</div></div>
        </div>
        <a class="button button--primary" href={contactConfig.instagramUrl} target="_blank" rel="noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>
          Seguir no Instagram
        </a>
      </div>
      <div class="ig-grid">
        {fallback.map((item) => (
          <a class="ig-tile" href={contactConfig.instagramUrl} target="_blank" rel="noreferrer" aria-label={item.caption}>
            <img src={item.mediaUrl} alt={item.caption} width="800" height="800" loading="lazy" />
          </a>
        ))}
      </div>
      <p class="ig-pending">Prévia de temas do perfil — siga {contactConfig.instagramHandle} para ver as publicações mais recentes.</p>
    </div>
  </div>
</section>
<script>
  const elfsight = document.getElementById('igElfsight');
  const fallbackEl = document.getElementById('igFallback');
  const appDiv = elfsight?.querySelector('[class^="elfsight-app-"]') as HTMLElement | null;

  function hasRendered() {
    if (!appDiv) return false;
    // A Elfsight injeta imagens/iframes e dá altura real ao container quando carrega
    const rendered = appDiv.querySelector('img, iframe, canvas, [class*="eapps"]');
    return !!rendered || appDiv.offsetHeight > 150;
  }

  function showFallback() {
    if (elfsight) elfsight.hidden = true;
    if (fallbackEl) fallbackEl.hidden = false;
  }

  // Verifica algumas vezes ao longo de ~9s antes de decidir que o widget falhou
  let attempts = 0;
  const maxAttempts = 6;
  const timer = window.setInterval(() => {
    attempts += 1;
    if (hasRendered()) {
      window.clearInterval(timer);
      return; // widget carregou: mantém a Elfsight
    }
    if (attempts >= maxAttempts) {
      window.clearInterval(timer);
      showFallback();
    }
  }, 1500);
</script>
<style>
.ig-embed-eyebrow { justify-content: center; text-align: center; width: 100%; margin: 0 0 1.75rem; }
.chapter-mark { display: inline-flex; align-items: center; gap: .3rem; flex: none; }
.chapter-num { font-family: var(--font-mono); font-weight: 700; }
.chapter-dash { opacity: .75; }

/* Seção nativa de fallback (mesmo visual da InstagramSection) */
.ig-head { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2.125rem; }
.ig-profile { display: flex; align-items: center; gap: 1.125rem; }
.ig-avatar { width: 4.625rem; height: 4.625rem; border-radius: 50%; padding: 3px; background: var(--grad-brand); flex: none; }
.ig-avatar div { width: 100%; height: 100%; border-radius: 50%; background: var(--color-white); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.ig-avatar img { width: 65%; height: 65%; object-fit: contain; }
.ig-profile .handle { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.375rem; font-weight: 800; color: var(--color-text); }
.ig-profile .name { font-size: .875rem; color: var(--color-muted); margin-top: .125rem; }
.ig-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: .5rem; max-width: 44rem; margin: 0 auto; }
.ig-tile { position: relative; aspect-ratio: 1/1; border-radius: .55rem; overflow: hidden; border: 1px solid var(--color-border); display: block; }
.ig-tile:hover img { transform: scale(1.035); }
.ig-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform .25s ease; }
.ig-pending { margin-top: 1.125rem; font-size: .78rem; color: var(--color-muted); text-align: center; }
@media (max-width: 760px) { .ig-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 650px) { .ig-head { align-items: start; flex-direction: column; } .ig-grid { grid-template-columns: repeat(3, 1fr); gap: .375rem; } }
</style>
