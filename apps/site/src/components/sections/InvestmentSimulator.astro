---
import SectionTitle from '../common/SectionTitle.astro';
import { contactConfig } from '../../config/contact';

const profiles = [
  { id: 'pf', label: 'Pessoa física', rate: 440, discount: true },
  { id: 'mei', label: 'MEI', rate: 440, discount: true },
  { id: 'meepp', label: 'ME/EPP', rate: 440, discount: true },
  { id: 'demais', label: 'Demais empresas', rate: 880, discount: false }
];
const classes = [
  { id: '1', label: '1', count: 1 },
  { id: '2', label: '2', count: 2 },
  { id: '3', label: '3 ou mais', count: 3, atLeast: true }
];
const plans = [
  { id: 'bronze', label: 'Bronze', price: 680 },
  { id: 'prata', label: 'Prata', price: 1487.5 },
  { id: 'ouro', label: 'Ouro', price: null }
];
---
<section class="section section--dark sim divider-cut" id="simulador">
  <div class="sim-pattern" aria-hidden="true"></div>
  <div class="container">
    <SectionTitle
      eyebrow="Simulador de investimento"
      title="Veja o custo antes de contratar"
      description="Escolha o perfil, a quantidade de classes e o plano. Mostramos as duas contas separadas: o que é da Registrium e o que vai direto para o INPI."
    />
    <div class="sim-card reveal" id="simCard" data-whatsapp={contactConfig.whatsappNumber}>
      <div class="sim-controls">
        <fieldset class="sim-group">
          <legend>Perfil</legend>
          <div class="sim-options" role="radiogroup" aria-label="Perfil">
            {profiles.map((p, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-perfil" value={p.id} data-rate={p.rate} checked={i === 0} />
                <span>{p.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
        <fieldset class="sim-group">
          <legend>Quantidade de classes</legend>
          <div class="sim-options" role="radiogroup" aria-label="Quantidade de classes">
            {classes.map((c, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-classes" value={c.id} data-count={c.count} data-atleast={c.atLeast ? '1' : '0'} checked={i === 0} />
                <span>{c.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
        <fieldset class="sim-group">
          <legend>Plano</legend>
          <div class="sim-options" role="radiogroup" aria-label="Plano">
            {plans.map((p, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-plano" value={p.id} data-price={p.price ?? ''} checked={i === 0} />
                <span>{p.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <div class="sim-result">
        <img class="sim-result-mark" src="/images/logo-mark-white.png" alt="" aria-hidden="true" />
        <div class="sim-table" role="table" aria-label="Resultado da simulação">
          <div class="sim-row sim-head" role="row">
            <span role="columnheader">Destino</span>
            <span role="columnheader">Valor</span>
          </div>
          <div class="sim-row" role="row">
            <span class="sim-dest" role="cell">
              <span class="sim-badge sim-badge--reg">Registrium</span>
              <span class="sim-sub">pagamento único</span>
            </span>
            <span class="sim-val" id="simReg" role="cell">R$ 680,00</span>
          </div>
          <div class="sim-row" role="row">
            <span class="sim-dest" role="cell">
              <span class="sim-badge sim-badge--inpi">INPI</span>
              <span class="sim-sub">direto ao órgão federal</span>
            </span>
            <span class="sim-val" id="simInpi" role="cell">R$ 440,00</span>
          </div>
          <div class="sim-row sim-total" role="row">
            <span class="sim-dest" role="cell">Total inicial</span>
            <span class="sim-val" id="simTotal" role="cell">R$ 1.120,00</span>
          </div>
        </div>
        <p class="sim-note" id="simNote">O valor da Registrium é pago uma vez só. A taxa do INPI vai inteira para o órgão federal e não passa pela Registrium.</p>
        <a class="button button--primary sim-cta" id="simCta" href="#cadastro" target="_blank" rel="noreferrer">
          Falar sobre este cenário
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <p class="sim-legal">Estimativa com base na tabela pública do INPI (Portaria GM/MDIC nº 110/2025). O desconto de 50% na taxa do INPI é autodeclarado no e-INPI para pessoa física, MEI e ME/EPP. Cada plano cobre 1 classe; classes adicionais são cotadas antes da contratação. Simulação informativa, não é proposta contratual.</p>
  </div>
</section>
<script>
  const card = document.getElementById('simCard') as HTMLElement | null;
  if (card) {
    const whatsapp = card.dataset.whatsapp || '';
    const regEl = document.getElementById('simReg') as HTMLElement;
    const inpiEl = document.getElementById('simInpi') as HTMLElement;
    const totalEl = document.getElementById('simTotal') as HTMLElement;
    const noteEl = document.getElementById('simNote') as HTMLElement;
    const ctaEl = document.getElementById('simCta') as HTMLAnchorElement;

    const brl = (v: number) =>
      v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

    const getChecked = (name: string) =>
      card.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`);

    const labelFor = (input: HTMLInputElement | null) =>
      input?.parentElement?.querySelector('span')?.textContent ?? '';

    const baseNote =
      'O valor da Registrium é pago uma vez só. A taxa do INPI vai inteira para o órgão federal e não passa pela Registrium.';
    const quoteNote =
      'Bronze e Prata cobrem 1 classe. Para mais de uma classe, o valor da Registrium é cotado antes — por isso mostramos “a partir de”. A taxa do INPI ao lado é exata.';

    function update() {
      const perfil = getChecked('sim-perfil');
      const cls = getChecked('sim-classes');
      const plano = getChecked('sim-plano');
      if (!perfil || !cls || !plano) return;

      const rate = Number(perfil.dataset.rate);
      const count = Number(cls.dataset.count);
      const atLeast = cls.dataset.atleast === '1';
      const priceRaw = plano.dataset.price;
      const hasPrice = priceRaw !== '';
      const regBase = hasPrice ? Number(priceRaw) : null;

      const inpiValue = count * rate;
      const inpiPrefix = atLeast ? 'a partir de ' : '';
      inpiEl.textContent = inpiPrefix + brl(inpiValue);

      // Ouro: sob consulta
      if (regBase === null) {
        regEl.textContent = 'Sob consulta';
        totalEl.textContent = 'Sob consulta';
        noteEl.textContent =
          'O plano Ouro é sob consulta, com diagnóstico gratuito antes de qualquer valor. A taxa do INPI ao lado já é a oficial para o perfil escolhido.';
      } else if (count > 1) {
        // Bronze/Prata cobrem 1 classe; classes extras cotadas
        regEl.textContent = 'a partir de ' + brl(regBase);
        totalEl.textContent = 'a partir de ' + brl(regBase + inpiValue);
        noteEl.textContent = quoteNote;
      } else {
        regEl.textContent = brl(regBase);
        totalEl.textContent = brl(regBase + inpiValue);
        noteEl.textContent = baseNote;
      }

      // Prefill WhatsApp with the chosen scenario
      let msg = 'Olá! Fiz uma simulação no site e quero falar sobre este cenário.\n\n';
      msg += `Perfil: ${labelFor(perfil)}\n`;
      msg += `Classes: ${labelFor(cls)}\n`;
      msg += `Plano: ${labelFor(plano)}\n`;
      msg += `Registrium: ${regEl.textContent}\n`;
      msg += `INPI: ${inpiEl.textContent}\n`;
      msg += `Total inicial: ${totalEl.textContent}`;
      ctaEl.href = whatsapp
        ? `https://wa.me/${whatsapp}?text=${encodeURIComponent(msg)}`
        : '#cadastro';
    }

    card.querySelectorAll('input[type="radio"]').forEach((el) =>
      el.addEventListener('change', update)
    );
    update();
  }
</script>
<style>
.sim { position: relative; overflow: hidden; background:
    radial-gradient(70% 80% at 80% 10%, rgba(62,111,230,.28), transparent 62%),
    radial-gradient(60% 70% at 10% 95%, rgba(138,87,206,.24), transparent 66%),
    var(--color-navy-900); }
.sim-pattern { position: absolute; inset: 0; z-index: 0; background-image: url('/images/logo-mark-white.png'); background-repeat: repeat; background-size: 7.5rem 7rem; opacity: .03; pointer-events: none; }
.sim .container { position: relative; z-index: 1; }
.sim-card { display: grid; grid-template-columns: 1.05fr .95fr; gap: 1.5rem; max-width: 60rem; margin: 0 auto; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); padding: 1.75rem; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); }

.sim-controls { display: flex; flex-direction: column; gap: 1.5rem; }
.sim-group { border: none; margin: 0; padding: 0; min-width: 0; }
.sim-group legend { padding: 0; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #9fb4ff; margin-bottom: .75rem; }
.sim-options { display: flex; flex-wrap: wrap; gap: .5rem; }
.sim-opt { position: relative; }
.sim-opt input { position: absolute; opacity: 0; width: 0; height: 0; }
.sim-opt span { display: inline-flex; align-items: center; justify-content: center; padding: .6rem 1rem; border-radius: 999px; border: 1px solid rgba(255,255,255,.18); background: rgba(255,255,255,.05); color: var(--color-on-dark); font-family: 'Plus Jakarta Sans', sans-serif; font-size: .87rem; font-weight: 600; cursor: pointer; transition: border-color .2s var(--ease-premium), background .2s ease, color .2s ease, transform .2s var(--ease-premium); }
.sim-opt span:hover { border-color: rgba(255,255,255,.4); color: var(--color-white); }
.sim-opt input:checked + span { background: var(--grad-brand); border-color: transparent; color: var(--color-white); transform: translateY(-1px); box-shadow: 0 10px 22px -12px rgba(90,70,210,.9); }
.sim-opt input:focus-visible + span { outline: 2.5px solid #8fd0f5; outline-offset: 2px; }

.sim-result { position: relative; overflow: hidden; background: linear-gradient(160deg, #241a52, #12123a); border: 1px solid rgba(255,255,255,.1); border-radius: var(--radius-md); padding: 1.5rem 1.625rem; display: flex; flex-direction: column; }
.sim-result-mark { position: absolute; z-index: 0; right: -1.5rem; bottom: -1.5rem; width: 9rem; opacity: .07; pointer-events: none; }
.sim-table { position: relative; z-index: 1; display: flex; flex-direction: column; }
.sim-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .875rem 0; border-bottom: 1px solid rgba(255,255,255,.1); }
.sim-row.sim-head { padding-top: 0; }
.sim-head span { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-on-dark-soft); }
.sim-dest { display: flex; flex-direction: column; gap: .3rem; }
.sim-badge { display: inline-flex; align-items: center; width: fit-content; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .8rem; font-weight: 800; padding: .2rem .6rem; border-radius: 999px; }
.sim-badge--reg { background: var(--grad-brand); color: var(--color-white); }
.sim-badge--inpi { background: rgba(255,255,255,.1); color: var(--color-white); border: 1px solid rgba(255,255,255,.22); }
.sim-sub { font-size: .72rem; color: var(--color-on-dark-soft); }
.sim-val { font-family: var(--font-mono); font-feature-settings: "tnum" 1; letter-spacing: -.03em; font-weight: 600; font-size: 1.02rem; color: var(--color-white); text-align: right; white-space: nowrap; }
.sim-total { border-bottom: none; padding-bottom: .25rem; margin-top: .25rem; }
.sim-total .sim-dest { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.06rem; color: var(--color-white); }
.sim-total .sim-val { font-size: 1.5rem; background: var(--grad-cyan); -webkit-background-clip: text; background-clip: text; color: transparent; }
.sim-note { position: relative; z-index: 1; font-size: .76rem; color: var(--color-on-dark); line-height: 1.55; margin: 1rem 0 1.25rem; min-height: 2.4rem; }
.sim-cta { position: relative; z-index: 1; width: 100%; margin-top: auto; }
.sim-legal { max-width: 46rem; margin: 1.5rem auto 0; font-size: .74rem; color: var(--color-on-dark-soft); text-align: center; line-height: 1.55; }

@media (max-width: 860px) { .sim-card { grid-template-columns: 1fr; } }
@media (max-width: 560px) { .sim-card { padding: 1.375rem; } .sim-opt span { padding: .55rem .85rem; font-size: .84rem; } }
</style>
