---
import SectionTitle from '../common/SectionTitle.astro';
import { contactConfig } from '../../config/contact';
import { plans } from '../../data/plans';

const profiles = [
  { id: 'pf', label: 'Pessoa física', rate: 440 },
  { id: 'mei', label: 'MEI', rate: 440 },
  { id: 'meepp', label: 'ME/EPP', rate: 440 },
  { id: 'demais', label: 'Demais empresas', rate: 880 }
];
const classes = [
  { id: '1', label: '1', count: 1 },
  { id: '2', label: '2', count: 2 },
  { id: '3', label: '3 ou mais', count: 3, atLeast: true }
];
const paymentMethods = [
  { id: 'pix', label: 'Pix / à vista (15% off)' },
  { id: 'cartao', label: 'Cartão em até 12x' }
];

// Dados completos dos planos (mesma fonte usada pela seção "Planos"), preparados para o cliente.
const plansData = plans.map((p) => ({
  id: p.id,
  name: p.name,
  category: p.category,
  who: p.who,
  tagline: p.tagline,
  priceNote: p.priceNote,
  items: p.items,
  footnote: 'footnote' in p ? p.footnote : null,
  eligibleProfiles: p.eligibleProfiles,
  pixValue: p.pixValue,
  cardTotal: p.cardTotal,
  cardInstallments: p.cardInstallments
}));

const profileLabels = Object.fromEntries(profiles.map((p) => [p.id, p.label]));
---
<section class="section section--dark sim divider-cut" id="simulador">
  <div class="sim-pattern" aria-hidden="true"></div>
  <div class="container">
    <SectionTitle
      chapter="09"
      eyebrow="Simulador de investimento"
      title="Veja o custo antes de contratar"
      description="Escolha o perfil, a quantidade de classes, o plano e a forma de pagamento. Mostramos as duas contas separadas: o que é da Registrium e o que vai direto para o INPI — e tudo que está incluso no plano escolhido."
    />
    <div class="sim-card reveal" id="simCard" data-whatsapp={contactConfig.whatsappNumber}>
      <div class="sim-controls">
        <fieldset class="sim-group">
          <legend>Perfil</legend>
          <div class="sim-options" role="radiogroup" aria-label="Perfil">
            {profiles.map((p, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-perfil" value={p.id} data-rate={p.rate} checked={i === 0} />
                <span>{p.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
        <fieldset class="sim-group">
          <legend>Quantidade de classes</legend>
          <div class="sim-options" role="radiogroup" aria-label="Quantidade de classes">
            {classes.map((c, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-classes" value={c.id} data-count={c.count} data-atleast={c.atLeast ? '1' : '0'} checked={i === 0} />
                <span>{c.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
        <fieldset class="sim-group">
          <legend>Plano</legend>
          <div class="sim-options" role="radiogroup" aria-label="Plano">
            {plansData.map((p, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-plano" value={p.id} checked={i === 0} />
                <span>{p.name} — {p.category}</span>
              </label>
            ))}
          </div>
          <p class="sim-hint" id="simPlanoHint">&nbsp;</p>
        </fieldset>
        <fieldset class="sim-group">
          <legend>Forma de pagamento à Registrium</legend>
          <div class="sim-options" role="radiogroup" aria-label="Forma de pagamento">
            {paymentMethods.map((p, i) => (
              <label class="sim-opt">
                <input type="radio" name="sim-pagamento" value={p.id} checked={i === 0} />
                <span>{p.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <div class="sim-result">
        <img class="sim-result-mark" src="/images/logo-mark-white.png" alt="" aria-hidden="true" />
        <div class="sim-table" role="table" aria-label="Resultado da simulação">
          <div class="sim-row sim-head" role="row">
            <span role="columnheader">Destino</span>
            <span role="columnheader">Valor</span>
          </div>
          <div class="sim-row" role="row">
            <span class="sim-dest" role="cell">
              <span class="sim-badge sim-badge--reg">Registrium</span>
              <span class="sim-sub" id="simRegSub">pagamento único</span>
            </span>
            <span class="sim-val" id="simReg" role="cell">R$ 680,00</span>
          </div>
          <div class="sim-row" role="row">
            <span class="sim-dest" role="cell">
              <span class="sim-badge sim-badge--inpi">INPI</span>
              <span class="sim-sub">direto ao órgão federal</span>
            </span>
            <span class="sim-val" id="simInpi" role="cell">R$ 440,00</span>
          </div>
          <div class="sim-row sim-total" role="row">
            <span class="sim-dest" role="cell">Total inicial</span>
            <span class="sim-val" id="simTotal" role="cell">R$ 1.120,00</span>
          </div>
        </div>
        <p class="sim-savings" id="simSavings"></p>
        <p class="sim-card-terms" id="simCardTerms">Parcelamos em até 3x sem juros no cartão. Parcelas adicionais, até 12x, e eventuais juros ficam a critério da sua operadora de cartão.</p>
        <p class="sim-note" id="simNote">O valor da Registrium é pago uma vez só. A taxa do INPI vai inteira para o órgão federal e não passa pela Registrium.</p>
        <a class="button button--primary sim-cta" id="simCta" href="#cadastro" target="_blank" rel="noreferrer">
          Falar sobre este cenário
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <div class="sim-included reveal" id="simIncluded">
      <div class="sim-included-head">
        <div>
          <span class="sim-included-who" id="simIncludedWho">MEI e Pessoa Física</span>
          <h3><span id="simIncludedTitle">O que está incluso no Bronze</span> <span class="sim-included-cat" id="simIncludedCat">Essencial</span></h3>
        </div>
        <p class="sim-included-tagline" id="simIncludedTagline">Para quem deseja iniciar o registro com segurança, clareza e acompanhamento profissional.</p>
      </div>
      <ul class="sim-included-list" id="simIncludedList"></ul>
      <p class="sim-included-footnote" id="simIncludedFootnote"></p>
    </div>

    <p class="sim-legal">Estimativa com base na tabela pública do INPI (Portaria GM/MDIC nº 110/2025) e nos planos e condições de pagamento publicados nesta página. O desconto de 50% na taxa do INPI é autodeclarado no e-INPI para pessoa física, MEI e ME/EPP. Cada plano cobre 1 classe; classes adicionais são cotadas antes da contratação. Simulação informativa, não é proposta contratual.</p>
  </div>
</section>
<script define:vars={{ plansData, profileLabels }}>
  const card = document.getElementById('simCard');
  if (card) {
    const whatsapp = card.dataset.whatsapp || '';
    const regEl = document.getElementById('simReg');
    const regSubEl = document.getElementById('simRegSub');
    const inpiEl = document.getElementById('simInpi');
    const totalEl = document.getElementById('simTotal');
    const noteEl = document.getElementById('simNote');
    const ctaEl = document.getElementById('simCta');
    const planoHintEl = document.getElementById('simPlanoHint');
    const incWhoEl = document.getElementById('simIncludedWho');
    const incTitleEl = document.getElementById('simIncludedTitle');
    const incCatEl = document.getElementById('simIncludedCat');
    const incTaglineEl = document.getElementById('simIncludedTagline');
    const incListEl = document.getElementById('simIncludedList');
    const incFootnoteEl = document.getElementById('simIncludedFootnote');
    const savingsEl = document.getElementById('simSavings');
    const cardTermsEl = document.getElementById('simCardTerms');

    // A Registrium parcela em até 3x sem juros no cartão. O rótulo do seletor
    // continua anunciando "até 12x" (parcelas extras + juros ficam com a operadora do cliente).
    const CARD_DISPLAY_INSTALLMENTS = 3;

    const checkIcon =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';
    const inheritedIcon =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    const brl = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

    const getChecked = (name) => card.querySelector(`input[name="${name}"]:checked`);
    const getPlan = (id) => plansData.find((p) => p.id === id);

    const baseNote =
      'O valor da Registrium é pago uma vez só. A taxa do INPI vai inteira para o órgão federal e não passa pela Registrium.';
    const negotiateNote =
      'A partir de 3 classes, aplicamos um desconto especial, negociado diretamente com o CEO da Registrium. A taxa do INPI ao lado já considera a quantidade de classes.';

    const FORCED_PLAN_BY_PROFILE = { meepp: 'prata', demais: 'ouro' };

    function applyProfileDefault(perfilId) {
      const forced = FORCED_PLAN_BY_PROFILE[perfilId];
      if (!forced) return;
      const target = card.querySelector(`input[name="sim-plano"][value="${forced}"]`);
      if (target && !target.checked) target.checked = true;
    }

    function syncPlanEligibility(perfilId) {
      const planoInputs = [...card.querySelectorAll('input[name="sim-plano"]')];
      const blocked = [];
      planoInputs.forEach((el) => {
        const plan = getPlan(el.value);
        const eligible = plan.eligibleProfiles.includes(perfilId);
        el.disabled = !eligible;
        el.closest('.sim-opt')?.classList.toggle('is-disabled', !eligible);
        if (!eligible) blocked.push(plan.name);
      });
      const current = getChecked('sim-plano');
      if (!current || current.disabled) {
        const firstEligible = planoInputs.find((el) => !el.disabled);
        if (firstEligible) firstEligible.checked = true;
      }
      if (blocked.length) {
        planoHintEl.textContent = `${profileLabels[perfilId]} não contrata: ${blocked.join(', ')}.`;
      } else {
        planoHintEl.textContent = ' ';
      }
    }

    function update() {
      const perfilInput = getChecked('sim-perfil');
      const clsInput = getChecked('sim-classes');
      const pagInput = getChecked('sim-pagamento');
      if (!perfilInput || !clsInput || !pagInput) return;

      const perfilId = perfilInput.value;
      syncPlanEligibility(perfilId);

      const planoInput = getChecked('sim-plano');
      if (!planoInput) return;
      const plan = getPlan(planoInput.value);
      const payMethod = pagInput.value;

      const rate = Number(perfilInput.dataset.rate);
      const count = Number(clsInput.dataset.count);
      const atLeast = clsInput.dataset.atleast === '1';
      const negotiate = atLeast; // "3 ou mais": honorários sob negociação direta com o CEO

      const inpiValue = count * rate;
      inpiEl.textContent = (atLeast ? 'a partir de ' : '') + brl(inpiValue);

      const hasPrice = plan.pixValue !== null && !negotiate;
      let regValue = null;

      if (negotiate) {
        regEl.textContent = 'Negociação direta';
        regSubEl.textContent = '3 ou mais classes · fale com o CEO';
      } else if (plan.pixValue === null) {
        regEl.textContent = 'Sob consulta';
        regSubEl.textContent = plan.priceNote;
      } else {
        const basePix = plan.pixValue * count;
        const baseCard = plan.cardTotal * count;
        const base = payMethod === 'cartao' ? baseCard : basePix;
        regValue = base;
        regEl.textContent = brl(base);
        regSubEl.textContent =
          payMethod === 'cartao'
            ? `${CARD_DISPLAY_INSTALLMENTS}x de ${brl(base / CARD_DISPLAY_INSTALLMENTS)} sem juros`
            : 'pagamento único no Pix (15% off)';
      }

      if (negotiate) {
        totalEl.textContent = 'Negociação direta';
      } else if (regValue === null) {
        totalEl.textContent = 'Sob consulta';
      } else {
        totalEl.textContent = brl(regValue + inpiValue);
      }

      if (hasPrice) {
        const economy = plan.cardTotal * count - plan.pixValue * count;
        savingsEl.textContent =
          payMethod === 'cartao'
            ? `Economize ${brl(economy)} pagando no Pix / à vista.`
            : `Você já está economizando ${brl(economy)} pagando no Pix.`;
        savingsEl.style.display = 'block';
      } else {
        savingsEl.style.display = 'none';
      }

      cardTermsEl.style.display = hasPrice && payMethod === 'cartao' ? 'block' : 'none';

      if (negotiate) {
        noteEl.textContent = negotiateNote;
      } else if (!hasPrice) {
        noteEl.textContent =
          'O plano Ouro é sob consulta, com diagnóstico gratuito antes de qualquer valor. A taxa do INPI ao lado já é a oficial para o perfil escolhido.';
      } else {
        noteEl.textContent = baseNote;
      }

      // Painel "o que está incluso"
      incWhoEl.textContent = plan.who;
      incTitleEl.textContent = `O que está incluso no ${plan.name}`;
      incCatEl.textContent = plan.category;
      incTaglineEl.textContent = plan.tagline;
      incListEl.innerHTML = plan.items
        .map((item) => {
          const inherited = item.startsWith('Tudo do');
          const icon = inherited ? inheritedIcon : checkIcon;
          return `<li class="${inherited ? 'sim-item-inherited' : 'sim-item-new'}">${icon}${item}</li>`;
        })
        .join('');
      if (plan.footnote) {
        incFootnoteEl.innerHTML = checkIcon + `<span>${plan.footnote}</span>`;
        incFootnoteEl.style.display = 'flex';
      } else {
        incFootnoteEl.style.display = 'none';
      }

      // WhatsApp com o cenário preenchido
      let msg = 'Olá! Fiz uma simulação no site e quero falar sobre este cenário.\n\n';
      msg += `Perfil: ${profileLabels[perfilId]}\n`;
      msg += `Classes: ${clsInput.parentElement?.querySelector('span')?.textContent ?? ''}\n`;
      msg += `Plano: ${plan.name} (${plan.category})\n`;
      msg += `Pagamento: ${payMethod === 'cartao' ? 'Cartão parcelado' : 'Pix / à vista'}\n`;
      msg += `Registrium: ${regEl.textContent}\n`;
      msg += `INPI: ${inpiEl.textContent}\n`;
      msg += `Total inicial: ${totalEl.textContent}`;
      ctaEl.href = whatsapp ? `https://wa.me/${whatsapp}?text=${encodeURIComponent(msg)}` : '#cadastro';
    }

    card.querySelectorAll('input[name="sim-perfil"]').forEach((el) =>
      el.addEventListener('change', () => {
        applyProfileDefault(el.value);
        update();
      })
    );
    card
      .querySelectorAll('input[name="sim-classes"], input[name="sim-plano"], input[name="sim-pagamento"]')
      .forEach((el) => el.addEventListener('change', update));
    update();
  }
</script>
<style>
.sim { position: relative; overflow: hidden; background:
    radial-gradient(70% 80% at 80% 10%, rgba(62,111,230,.28), transparent 62%),
    radial-gradient(60% 70% at 10% 95%, rgba(138,87,206,.24), transparent 66%),
    var(--color-navy-900); }
.sim-pattern { position: absolute; inset: 0; z-index: 0; background-image: url('/images/logo-mark-white.png'); background-repeat: repeat; background-size: 7.5rem 7rem; opacity: .03; pointer-events: none; }
.sim .container { position: relative; z-index: 1; }
.sim-card { display: grid; grid-template-columns: 1.05fr .95fr; gap: 1.5rem; max-width: 60rem; margin: 0 auto; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); padding: 1.75rem; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); }

.sim-controls { display: flex; flex-direction: column; gap: 1.375rem; }
.sim-group { border: none; margin: 0; padding: 0; min-width: 0; }
.sim-group legend { padding: 0; font-family: var(--font-ui); font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #9fb4ff; margin-bottom: .75rem; }
.sim-options { display: flex; flex-wrap: wrap; gap: .5rem; }
.sim-opt { position: relative; }
.sim-opt input { position: absolute; opacity: 0; width: 0; height: 0; }
.sim-opt span { display: inline-flex; align-items: center; justify-content: center; padding: .6rem 1rem; border-radius: 999px; border: 1px solid rgba(255,255,255,.18); background: rgba(255,255,255,.05); color: var(--color-on-dark); font-family: var(--font-ui); font-size: .87rem; font-weight: 600; cursor: pointer; transition: border-color .2s var(--ease-premium), background .2s ease, color .2s ease, transform .2s var(--ease-premium), opacity .2s ease; }
.sim-opt span:hover { border-color: rgba(255,255,255,.4); color: var(--color-white); }
.sim-opt input:checked + span { background: var(--grad-brand); border-color: transparent; color: var(--color-white); transform: translateY(-1px); box-shadow: 0 10px 22px -12px rgba(90,70,210,.9); }
.sim-opt input:checked + span::before { content: "✓"; margin-right: .4rem; font-weight: 800; }
.sim-opt input:focus-visible + span { outline: 2.5px solid #8fd0f5; outline-offset: 2px; }
.sim-opt input:disabled + span { opacity: .32; cursor: not-allowed; text-decoration: line-through; }
.sim-opt input:disabled + span:hover { border-color: rgba(255,255,255,.18); color: var(--color-on-dark); transform: none; }
.sim-hint { min-height: 1.1rem; margin: .625rem 0 0; font-size: .74rem; color: #f5c895; }

.sim-result { position: relative; overflow: hidden; background: linear-gradient(160deg, #241a52, #12123a); border: 1px solid rgba(255,255,255,.1); border-radius: var(--radius-md); padding: 1.5rem 1.625rem; display: flex; flex-direction: column; }
.sim-result-mark { position: absolute; z-index: 0; right: -1.5rem; bottom: -1.5rem; width: 9rem; opacity: .07; pointer-events: none; }
.sim-table { position: relative; z-index: 1; display: flex; flex-direction: column; }
.sim-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .875rem 0; border-bottom: 1px solid rgba(255,255,255,.1); }
.sim-row.sim-head { padding-top: 0; }
.sim-head span { font-family: var(--font-ui); font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-on-dark-soft); }
.sim-dest { display: flex; flex-direction: column; gap: .3rem; }
.sim-badge { display: inline-flex; align-items: center; width: fit-content; font-family: var(--font-ui); font-size: .8rem; font-weight: 800; padding: .2rem .6rem; border-radius: 999px; }
.sim-badge--reg { background: var(--grad-brand); color: var(--color-white); }
.sim-badge--inpi { background: rgba(255,255,255,.1); color: var(--color-white); border: 1px solid rgba(255,255,255,.22); }
.sim-sub { font-size: .72rem; color: var(--color-on-dark-soft); }
.sim-val { font-family: var(--font-mono); font-feature-settings: "tnum" 1; letter-spacing: -.03em; font-weight: 600; font-size: 1.02rem; color: var(--color-white); text-align: right; white-space: nowrap; }
.sim-total { border-bottom: none; padding-bottom: .25rem; margin-top: .25rem; }
.sim-total .sim-dest { font-family: var(--font-ui); font-weight: 800; font-size: 1.06rem; color: var(--color-white); }
.sim-total .sim-val { font-size: 1.4rem; background: var(--grad-cyan); -webkit-background-clip: text; background-clip: text; color: transparent; white-space: normal; text-align: right; }
.sim-savings { display: none; position: relative; z-index: 1; font-family: var(--font-ui); font-size: .78rem; font-weight: 700; color: #8fd0f5; margin: 1rem 0 0; }
.sim-card-terms { display: none; position: relative; z-index: 1; font-size: .7rem; color: var(--color-on-dark-soft); line-height: 1.5; margin: .5rem 0 0; }
.sim-note { position: relative; z-index: 1; font-size: .76rem; color: var(--color-on-dark); line-height: 1.55; margin: .5rem 0 1.25rem; min-height: 2.4rem; }
.sim-cta { position: relative; z-index: 1; width: 100%; margin-top: auto; }

.sim-included { position: relative; z-index: 1; margin: 1.5rem auto 0; max-width: 60rem; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); padding: 1.75rem; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); }
.sim-included-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: .375rem 1.5rem; margin-bottom: 1.25rem; padding-bottom: 1.125rem; border-bottom: 1px solid rgba(255,255,255,.1); }
.sim-included-who { display: block; font-family: var(--font-mono); font-size: .68rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: #9fb4ff; margin-bottom: .375rem; }
.sim-included-head h3 { display: flex; align-items: center; gap: .625rem; flex-wrap: wrap; font-family: var(--font-ui); font-size: 1.19rem; font-weight: 700; color: var(--color-white); margin: 0; }
.sim-included-cat { font-family: var(--font-ui); font-size: .68rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--color-white); background: var(--grad-brand); padding: .25rem .625rem; border-radius: 999px; }
.sim-included-tagline { font-size: .87rem; color: var(--color-on-dark-soft); margin: 0; max-width: 22rem; }
.sim-included-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem 1.5rem; }
.sim-included-list li { display: flex; gap: .625rem; font-size: .89rem; color: var(--color-on-dark); line-height: 1.45; }
.sim-included-list li svg { flex: none; margin-top: .15rem; }
.sim-item-new svg { color: #8fd0f5; }
.sim-item-inherited { opacity: .58; }
.sim-item-inherited svg { color: var(--color-on-dark-soft); }
.sim-included-footnote { display: flex; gap: .625rem; align-items: flex-start; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14); border-radius: .65rem; padding: .75rem .95rem; font-size: .78rem; color: var(--color-on-dark); line-height: 1.5; margin: 1.375rem 0 0; }
.sim-included-footnote svg { flex: none; color: #8fd0f5; margin-top: .1rem; }
.sim-legal { max-width: 46rem; margin: 1.5rem auto 0; font-size: .74rem; color: var(--color-on-dark-soft); text-align: center; line-height: 1.55; }

@media (max-width: 860px) { .sim-card { grid-template-columns: 1fr; } }
@media (max-width: 700px) { .sim-included-list { grid-template-columns: 1fr; } .sim-included-head { align-items: flex-start; } }
@media (max-width: 560px) { .sim-card, .sim-included { padding: 1.375rem; } .sim-opt span { padding: .55rem .85rem; font-size: .84rem; } }
</style>
