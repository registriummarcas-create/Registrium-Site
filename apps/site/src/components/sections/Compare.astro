---
import SectionTitle from '../common/SectionTitle.astro';
const oldWay = [
  'Pesquisa superficial',
  'Sem acompanhamento',
  'Serviço caro e taxas abusivas',
  'Cobranças extras a cada ato processual',
  'Controle manual, sem controle de colidência',
  'Documentos rebuscados e cheios de notas de rodapé',
  'Reclamações e processos arquivados'
];
const newWay = [
  'Pesquisa minuciosa e verdadeira sobre a viabilidade da marca',
  'Cumprimento das intimações no decorrer do processo',
  'Preço justo, sem cobranças abusivas',
  'Pagamento único na contratação',
  'Software com tecnologia de ponta',
  'Proteção contínua — sistema de vigilância preventiva',
  'Precificação e documentos com linguagem clara e honesta'
];
---
<section class="section section--dark compare" id="comparativo">
  <div class="container">
    <SectionTitle eyebrow="Por que isso importa" title="Registrium × Concorrência" description="Mesma necessidade, experiências opostas. Enquanto o mercado cobra caro e some no meio do caminho, aqui o preço está publicado e o processo é acompanhado por uma única equipe." />
    <div class="compare-grid reveal">
      <div class="compare-col old">
        <h3>Concorrência <span class="tag">R$ 2.500,00</span></h3>
        <ul>
          {oldWay.map((item) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="compare-divider"></div>
      <div class="compare-col new">
        <h3>Registrium <span class="tag grad">a partir de 12x R$ 64,14</span></h3>
        <ul>
          {newWay.map((item) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
<style>
.compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); overflow: hidden; max-width: 62.5rem; margin: 0 auto; }
.compare-col { padding: 2.125rem 2rem; }
.compare-col.old { background: rgba(255,255,255,.03); }
.compare-col.new { background: linear-gradient(160deg, rgba(120,80,210,.28), rgba(60,110,230,.12)); }
.compare-col h3 { color: var(--color-white); font-size: 1.125rem; font-weight: 700; margin-bottom: 1.375rem; display: flex; align-items: center; flex-wrap: wrap; gap: .625rem; }
.compare-col .tag { margin-left: auto; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .81rem; font-weight: 700; border: 1px solid rgba(255,255,255,.2); border-radius: 999px; padding: .3rem .75rem; }
.compare-col .tag.grad { background: var(--grad-brand); border-color: transparent; }
.compare-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
.compare-col li { display: flex; gap: .75rem; font-size: .91rem; color: #d7d3ee; line-height: 1.45; }
.compare-col.new li { color: #f1eefb; }
.compare-col li svg { flex: none; margin-top: .1rem; }
.compare-col.old li svg { color: #8b84ae; }
.compare-col.new li svg { color: #8fd0f5; }
.compare-divider { width: 1px; background: rgba(255,255,255,.14); }
@media (max-width: 920px) { .compare-grid { grid-template-columns: 1fr; } .compare-divider { display: none; } }
</style>
