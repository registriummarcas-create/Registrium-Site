---
import SectionTitle from '../common/SectionTitle.astro';

const rows = [
  { label: 'Pesquisa de viabilidade aprofundada', competitor: false },
  { label: 'Acompanhamento em todas as etapas do processo', competitor: false },
  { label: 'Preço justo e publicado', competitor: false },
  { label: 'Pagamento único, sem cobranças extras', competitor: false },
  { label: 'Pesquisa de colidência com IA', competitor: false },
  { label: 'Documentos e contratos em linguagem clara', competitor: false },
  { label: 'Vigilância preventiva contínua da marca', competitor: false },
  { label: 'Atendimento direto com a equipe responsável', competitor: 'dash' },
  { label: 'Consultoria personalizada antes de protocolar', competitor: 'dash' },
  { label: 'Protocolo do pedido em até 48h', competitor: 'dash' },
  { label: 'Garantia de novo pedido se indeferido', competitor: 'dash' }
] as const;

const checkIcon = '<path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>';
const crossIcon = '<path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>';
---
<section class="section section--dark compare" id="comparativo">
  <img class="compare-watermark" src="/images/logo-mark-white.png" alt="" aria-hidden="true" />
  <div class="container">
    <SectionTitle eyebrow="Por que isso importa" title="Registrium × Concorrência" description="Mesma necessidade, experiências opostas. Enquanto o mercado cobra caro e some no meio do caminho, aqui o preço está publicado e o processo é acompanhado por uma única equipe." />
    <div class="compare-wrap reveal">
      <div class="compare-table-scroll">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="col-label">Recursos</th>
              <th class="col-us">Registrium<span class="price grad">a partir de R$ 680,00</span></th>
              <th class="col-them">Concorrência<span class="price">R$ 2.000 a R$ 4.500 + custos por etapa</span></th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <td class="col-label">{row.label}</td>
                <td class="col-us"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={checkIcon} /></td>
                <td class="col-them">
                  {row.competitor === false
                    ? <svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={crossIcon} />
                    : <span class="dash">—</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="compare-cta">
        <a class="button button--primary" href="#cadastro">
          Quero registrar minha marca
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
<style>
.compare { position: relative; overflow: hidden; }
.compare-watermark { position: absolute; z-index: 0; top: -4rem; left: -5rem; width: 24rem; max-width: 60%; opacity: .06; pointer-events: none; user-select: none; animation: spinSlow 90s linear infinite; transform-origin: 60% 60%; }
.compare .container { position: relative; z-index: 1; }
.compare-wrap { max-width: 56rem; margin: 0 auto; }
.compare-table-scroll { overflow-x: auto; border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); background: rgba(255,255,255,.03); }
.compare-table { width: 100%; border-collapse: collapse; min-width: 34rem; }
.compare-table th, .compare-table td { padding: 1rem 1.25rem; text-align: center; }
.compare-table .col-label { text-align: left; }
.compare-table thead th { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 800; color: var(--color-white); border-bottom: 1px solid rgba(255,255,255,.14); }
.compare-table thead .col-label { font-size: .81rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--color-on-dark-soft); }
.compare-table .price { display: block; font-family: 'Inter', sans-serif; font-size: .72rem; font-weight: 600; color: var(--color-on-dark-soft); margin-top: .3rem; border-radius: 999px; padding: .25rem .6rem; border: 1px solid rgba(255,255,255,.18); }
.compare-table .price.grad { color: var(--color-white); background: var(--grad-brand); border-color: transparent; }
.compare-table tbody td { border-bottom: 1px solid rgba(255,255,255,.08); font-size: .88rem; color: #d7d3ee; }
.compare-table tbody tr:last-child td { border-bottom: none; }
.compare-table tbody tr:nth-child(even) { background: rgba(255,255,255,.03); }
.compare-table .col-us svg { color: #8fd0f5; }
.compare-table .col-them svg { color: #8b84ae; }
.compare-table .col-them .dash { color: var(--color-on-dark-soft); }
.compare-cta { display: flex; justify-content: center; margin-top: 2rem; }
@media (max-width: 560px) { .compare-table th, .compare-table td { padding: .8rem 1rem; } }
</style>
