---
import { contactConfig } from '../../config/contact';
---
<section class="section closing">
  <div class="container">
    <div class="cta-card reveal">
      <div>
        <h2>Pronto para proteger o que é seu?</h2>
        <p>Fale com um especialista Registrium e receba a análise de viabilidade da sua marca.</p>
        <a class="button button--secondary" href="#cadastro">
          Preencher cadastro
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="cta-contacts">
        <a class="cc-row" href={`tel:+${contactConfig.whatsappNumber}`}>
          <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 4-2 1.5a11 11 0 005 5l1.5-2 4 1.5V17a2 2 0 01-2 2A14 14 0 013 6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
          <span><span class="cc-k">Telefone</span><span class="cc-v">{contactConfig.phoneDisplay}</span></span>
        </a>
        <a class="cc-row" href={`mailto:${contactConfig.email}`}>
          <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="m4 7 8 5 8-5" stroke="currentColor" stroke-width="1.6"/></svg></span>
          <span><span class="cc-k">E-mail</span><span class="cc-v">{contactConfig.email}</span></span>
        </a>
        <a class="cc-row" href={contactConfig.instagramUrl} target="_blank" rel="noreferrer">
          <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/></svg></span>
          <span><span class="cc-k">Instagram</span><span class="cc-v">{contactConfig.instagramHandle}</span></span>
        </a>
      </div>
    </div>
  </div>
</section>
<style>
.closing { padding-bottom: 2.5rem; }
.cta-card { position: relative; overflow: hidden; border-radius: 1.75rem; border: 1px solid rgba(255,255,255,.1); color: var(--color-white); padding: 3.75rem 3.5rem;
  background: radial-gradient(120% 130% at 85% 20%, rgba(120,70,200,.4), transparent 55%), linear-gradient(120deg, var(--color-navy-950), var(--color-indigo-900) 60%, var(--color-purple-900));
  display: grid; grid-template-columns: 1.05fr .95fr; gap: 3.25rem; align-items: center; }
.cta-card h2 { color: var(--color-white); font-size: clamp(1.75rem, 3.6vw, 2.625rem); font-weight: 800; line-height: 1.08; }
.cta-card p { color: var(--color-on-dark); font-size: 1rem; line-height: 1.6; max-width: 26rem; margin: 1.125rem 0 1.875rem; }
.cta-contacts { display: flex; flex-direction: column; gap: .875rem; }
.cc-row { display: flex; align-items: center; gap: 1rem; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.13); border-radius: 1rem; padding: 1rem 1.25rem; text-decoration: none; transition: background .16s ease, border-color .16s ease; }
.cc-row:hover { background: rgba(255,255,255,.09); border-color: rgba(255,255,255,.25); }
.cc-ico { width: 2.625rem; height: 2.625rem; border-radius: .75rem; background: rgba(255,255,255,.08); display: flex; align-items: center; justify-content: center; flex: none; color: #9fd3f2; }
.cc-k { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .66rem; letter-spacing: .12em; text-transform: uppercase; color: var(--color-on-dark-soft); margin-bottom: .2rem; font-weight: 700; display: block; }
.cc-v { font-size: .97rem; color: var(--color-white); font-weight: 600; }
@media (max-width: 920px) { .cta-card { grid-template-columns: 1fr; gap: 2.25rem; padding: 2.75rem 2rem; } }
@media (max-width: 560px) { .cta-card { padding: 2.25rem 1.375rem; } }
</style>
