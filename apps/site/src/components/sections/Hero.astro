---
import { contactConfig } from '../../config/contact';
---
<header class="hero" id="top">
  <div class="container hero-grid">
    <div class="reveal">
      <span class="pill">
        <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z" fill="currentColor"/></svg>
        Credenciada no INPI
      </span>
      <h1>Sua marca protegida com <span class="g-cyan">transparência e</span> <span class="g-purple">tecnologia.</span></h1>
      <p class="hero-sub">Registramos e protegemos sua marca no INPI com pesquisa por inteligência artificial, acompanhamento diário e um pagamento único — sem pegadinhas.</p>
      <div class="hero-ctas">
        <a class="button button--secondary" href="#planos">Ver planos
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="button button--dark" href="#duvidas">Tirar dúvidas</a>
      </div>
      <div class="hero-divider"></div>
      <div class="hero-stats">
        <div><div class="s-num">48h</div><div class="s-lbl">para protocolo</div></div>
        <div><div class="s-num">10 anos</div><div class="s-lbl">de validade</div></div>
        <div><div class="s-num">100%</div><div class="s-lbl">transparência</div></div>
      </div>
    </div>
    <div class="hero-visual reveal">
      <span id="cadastro" class="hero-form-anchor" aria-hidden="true"></span>
      <div class="chat-card" id="heroChat" data-whatsapp-number={contactConfig.whatsappNumber}>
        <div class="chat-head">
          <div class="chat-avatar"><img src="/images/logo-mark.png" alt="Registrium" /></div>
          <div>
            <div class="chat-name">Registrium</div>
            <div class="chat-status"><span class="dot"></span> Vamos registrar sua marca</div>
          </div>
        </div>
        <div class="chat-body" id="chatBody">
          <div class="msg bot">Olá! 👋 Vamos começar o registro da sua marca. Qual é o seu nome completo?</div>
        </div>
        <form class="chat-input-row" id="chatForm">
          <input id="chatInput" name="chatInput" type="text" placeholder="Seu nome completo" autocomplete="off" required />
          <button type="submit" class="chat-send" aria-label="Enviar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2 11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 2 15 22l-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <p class="hero-form-note">Sem compromisso. Você fala direto com a Registrium pelo WhatsApp.</p>
      </div>
      <div class="hero-form-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
        88% de aprovação no INPI
      </div>
    </div>
  </div>
</header>
<script>
  const chat = document.getElementById('heroChat') as HTMLElement | null;
  if (chat) {
    const whatsappNumber = chat.dataset.whatsappNumber;
    const body = document.getElementById('chatBody') as HTMLElement;
    const form = document.getElementById('chatForm') as HTMLFormElement;
    const input = document.getElementById('chatInput') as HTMLInputElement;
    const sendBtn = form.querySelector('.chat-send') as HTMLButtonElement;

    type Step = { key: string; type: string; placeholder: string; question?: (d: Record<string, string>) => string };
    const steps: Step[] = [
      { key: 'nome', type: 'text', placeholder: 'Seu nome completo' },
      { key: 'marca', type: 'text', placeholder: 'Nome da marca', question: (d) => `Prazer, ${d.nome.split(' ')[0]}! Qual é o nome da marca que você quer registrar?` },
      { key: 'area', type: 'text', placeholder: 'Ex: moda, alimentação, tecnologia...', question: () => 'Em qual área ela atua?' },
      { key: 'cnpj', type: 'text', placeholder: 'CNPJ (ou "não tenho")', question: () => 'Você já tem CNPJ? Se ainda não tiver, pode digitar "não tenho".' },
      { key: 'whats', type: 'tel', placeholder: '(00) 00000-0000', question: () => 'Perfeito! Por último, qual o seu WhatsApp para a gente continuar por lá?' }
    ];

    const data: Record<string, string> = {};
    let stepIndex = 0;
    input.type = steps[0].type;
    input.placeholder = steps[0].placeholder;

    function scrollToEnd() {
      body.scrollTop = body.scrollHeight;
    }

    function addMessage(text: string, from: 'bot' | 'user') {
      const div = document.createElement('div');
      div.className = `msg ${from}`;
      div.textContent = text;
      body.appendChild(div);
      scrollToEnd();
    }

    function addTyping() {
      const div = document.createElement('div');
      div.className = 'msg bot typing';
      div.id = 'chatTyping';
      div.innerHTML = '<span></span><span></span><span></span>';
      body.appendChild(div);
      scrollToEnd();
    }

    function removeTyping() {
      document.getElementById('chatTyping')?.remove();
    }

    function finish() {
      input.disabled = true;
      sendBtn.disabled = true;
      addTyping();
      setTimeout(() => {
        removeTyping();
        addMessage('Perfeito! Vou te levar direto pro WhatsApp com tudo preenchido 🚀', 'bot');
        let message = 'Olá! Quero registrar minha marca com a Registrium.\n\n';
        message += `Nome: ${data.nome}\nMarca: ${data.marca}\nÁrea de atuação: ${data.area}\nWhatsApp: ${data.whats}`;
        if (data.cnpj && !/n[ãa]o/i.test(data.cnpj)) message += `\nCNPJ: ${data.cnpj}`;
        const cta = document.createElement('a');
        cta.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
        cta.target = '_blank';
        cta.rel = 'noopener';
        cta.className = 'button button--secondary chat-cta';
        cta.textContent = 'Continuar no WhatsApp';
        body.appendChild(cta);
        scrollToEnd();
      }, 600);
    }

    function askNext() {
      if (stepIndex >= steps.length) {
        finish();
        return;
      }
      const step = steps[stepIndex];
      const question = step.question ? step.question(data) : undefined;
      if (question) {
        addTyping();
        setTimeout(() => {
          removeTyping();
          addMessage(question, 'bot');
        }, 600);
      }
      input.type = step.type;
      input.placeholder = step.placeholder;
      input.focus();
    }

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const value = input.value.trim();
      if (!value) return;
      addMessage(value, 'user');
      data[steps[stepIndex].key] = value;
      input.value = '';
      stepIndex += 1;
      askNext();
    });
  }
</script>
<style>
.hero { position: relative; overflow: hidden; background:
    radial-gradient(120% 90% at 85% 40%, rgba(70,110,230,.28), transparent 55%),
    radial-gradient(90% 80% at 15% 10%, rgba(120,70,200,.22), transparent 60%),
    linear-gradient(125deg, var(--color-navy-950) 0%, var(--color-indigo-900) 55%, var(--color-purple-900) 100%); }
.hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.08fr .92fr; gap: 3rem; align-items: center; padding: 6rem 0 5.25rem; }
.hero-grid > * { min-width: 0; }
.pill { display: inline-flex; align-items: center; gap: .55rem; border: 1px solid rgba(255,255,255,.22); background: rgba(255,255,255,.06); color: var(--color-white); border-radius: 999px; padding: .55rem 1.05rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .75rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
.pill svg { width: .95rem; height: .95rem; color: #8fd0f5; }
.hero h1 { color: var(--color-white); font-weight: 800; font-size: clamp(2.6rem, 6vw, 4.6rem); line-height: 1.02; margin-top: 1.6rem; }
.hero h1 .g-cyan { background: var(--grad-cyan); -webkit-background-clip: text; background-clip: text; color: transparent; }
.hero h1 .g-purple { background: var(--grad-purple); -webkit-background-clip: text; background-clip: text; color: transparent; }
.hero-sub { color: var(--color-on-dark); font-size: 1.125rem; line-height: 1.6; max-width: 31rem; margin-top: 1.6rem; }
.hero-ctas { display: flex; gap: .875rem; margin-top: 2.1rem; flex-wrap: wrap; }
.hero-divider { height: 1px; background: rgba(255,255,255,.12); margin-top: 3.25rem; max-width: 38rem; }
.hero-stats { display: flex; gap: 3.5rem; margin-top: 1.6rem; flex-wrap: wrap; }
.hero-stats .s-num { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 2.1rem; color: var(--color-white); line-height: 1; }
.hero-stats .s-lbl { font-size: .84rem; color: var(--color-on-dark-soft); margin-top: .5rem; }
.hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
.hero-visual::before { content: ""; position: absolute; width: 80%; aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgba(90,120,240,.45), transparent 68%); filter: blur(34px); }

.chat-card { position: relative; width: 100%; max-width: 25rem; background: rgba(255,255,255,.97); border: 1px solid rgba(255,255,255,.6); border-radius: var(--radius-lg); padding: 0 1.375rem 1.25rem; box-shadow: 0 40px 80px -30px rgba(6,8,30,.55), 0 1px 0 rgba(255,255,255,.4) inset; display: flex; flex-direction: column; overflow: hidden; }
.chat-head { position: relative; display: flex; align-items: center; gap: .75rem; margin: 0 -1.375rem 1.125rem; padding: 1.125rem 1.375rem; background: var(--grad-brand); }
.chat-head::after { content: ""; position: absolute; inset: 0; background: radial-gradient(120% 140% at 100% 0%, rgba(255,255,255,.22), transparent 60%); }
.chat-avatar { position: relative; z-index: 1; width: 2.75rem; height: 2.75rem; border-radius: 50%; background: var(--color-white); display: flex; align-items: center; justify-content: center; flex: none; padding: .5rem; box-shadow: 0 6px 16px -6px rgba(6,8,30,.4); }
.chat-avatar img { width: 100%; height: 100%; object-fit: contain; }
.chat-name { position: relative; z-index: 1; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: .97rem; color: var(--color-white); }
.chat-status { position: relative; z-index: 1; display: flex; align-items: center; gap: .4rem; font-size: .78rem; color: rgba(255,255,255,.85); margin-top: .15rem; }
.chat-status .dot { width: .45rem; height: .45rem; border-radius: 50%; background: #4ade80; flex: none; box-shadow: 0 0 0 3px rgba(255,255,255,.25); }
.chat-body { display: flex; flex-direction: column; gap: .625rem; min-height: 13rem; max-height: 18rem; overflow-y: auto; padding-right: .25rem; }
.msg { max-width: 85%; font-size: .87rem; line-height: 1.45; padding: .6rem .875rem; border-radius: .875rem; }
.msg.bot { align-self: flex-start; background: #f2f2fb; color: var(--color-text); border-bottom-left-radius: .25rem; }
.msg.user { align-self: flex-end; background: var(--grad-brand); color: var(--color-white); border-bottom-right-radius: .25rem; }
.msg.typing { display: flex; align-items: center; gap: .3rem; padding: .75rem .95rem; }
.msg.typing span { width: .4rem; height: .4rem; border-radius: 50%; background: var(--color-muted); opacity: .5; animation: typingDot 1.1s ease-in-out infinite; }
.msg.typing span:nth-child(2) { animation-delay: .15s; }
.msg.typing span:nth-child(3) { animation-delay: .3s; }
@keyframes typingDot { 0%, 60%, 100% { opacity: .35; transform: translateY(0); } 30% { opacity: 1; transform: translateY(-2px); } }
.chat-cta { align-self: flex-start; margin-top: .25rem; }
.chat-input-row { display: flex; align-items: center; gap: .375rem; margin-top: 1rem; background: #f2f2fb; border: 1px solid var(--color-border); border-radius: 999px; padding: .3rem .3rem .3rem 1rem; transition: border-color .15s ease, box-shadow .15s ease; }
.chat-input-row:focus-within { border-color: var(--color-blue); box-shadow: 0 0 0 3px rgba(62,111,230,.14); }
.chat-input-row input { flex: 1; min-width: 0; font-family: 'Inter', sans-serif; font-size: .89rem; color: var(--color-text); background: transparent; border: none; padding: .55rem 0; outline: none; }
.chat-input-row input:disabled { opacity: .55; }
.chat-send { flex: none; width: 2.35rem; height: 2.35rem; border-radius: 50%; background: var(--grad-brand); color: var(--color-white); display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; transition: transform .15s ease, filter .15s ease; }
.chat-send:hover { filter: brightness(1.08); }
.chat-send:disabled { opacity: .5; cursor: default; }
.hero-form-note { font-size: .72rem; color: var(--color-muted); text-align: center; margin: .75rem 0 0; }
.hero-form-badge { position: absolute; left: 1.5rem; bottom: -1.1rem; z-index: 2; display: inline-flex; align-items: center; gap: .5rem; background: var(--color-white); border: 1px solid var(--color-border); color: var(--color-violet); border-radius: 999px; padding: .55rem 1rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .75rem; font-weight: 700; box-shadow: 0 14px 28px -14px rgba(6,8,30,.5); animation: badgeFloat 5s ease-in-out infinite; }
.hero-form-badge svg { flex: none; color: var(--color-violet); }
@keyframes badgeFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
@media (max-width: 920px) { .hero-grid { grid-template-columns: 1fr; gap: 1.25rem; padding: 4rem 0 4.25rem; } .hero-visual { order: -1; max-width: 25rem; margin: 0 auto; padding-bottom: 1.5rem; } }
@media (max-width: 560px) { .hero-ctas { flex-direction: column; } .hero-ctas .button { width: 100%; } .hero-stats { gap: 1.875rem; } .chat-card { padding: 1.125rem 1.125rem 1rem; } .hero-form-badge { font-size: .68rem; padding: .5rem .8rem; left: 1.1rem; } }
</style>
