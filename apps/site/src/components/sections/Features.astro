---
import SectionTitle from '../common/SectionTitle.astro';
const features = [
  {
    icon: '<path d="M6 3h9l4 4v14H6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/><path d="M15 3v4h4" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter"/><path d="M9 13h7M9 17h7" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/>',
    title: 'Protocolo em até 48h',
    description: 'Seu pedido de registro no INPI pronto em <strong>dois dias úteis</strong>.'
  },
  {
    icon: '<circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.6"/><path d="M14.8 14.8 20.5 20.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/>',
    title: 'Pesquisa com IA',
    description: 'Software com inteligência artificial para <strong>análise de colidência e viabilidade real</strong>.'
  },
  {
    icon: '<path d="M12 2 3 6v6c0 5 4 8.5 9 10 5-1.5 9-5 9-10V6l-9-4Z" stroke="currentColor" stroke-width="1.6"/><path d="M8.5 12.2 10.8 14.5 16 9.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" stroke-linejoin="miter"/>',
    title: 'Garantia de novo pedido',
    description: 'Nos planos Prata e Ouro, se o INPI indeferir, <strong>refazemos o processo sem novos honorários</strong>.'
  },
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7"/><path d="M8.5 12.5l2.2 2.2 4.8-4.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Formação Academia do INPI e WIPO',
    description: 'Equipe com formação pela Academia do INPI e WIPO Academy, com <strong>88% de aprovação nos pedidos protocolados desde 2021</strong>.'
  }
];
---
<section class="section section--dark feat-section divider-cut" id="empresa">
  <div class="feat-glow" aria-hidden="true"></div>
  <div class="container">
    <SectionTitle chapter="03" eyebrow="Por que Registrium" title="Registro de marca sem burocracia e com transparência" description="Desmitificamos o processo de registro e trazemos a segurança de uma equipe com formação pela Academia do INPI e WIPO Academy para empresas de todos os portes." />
    <div class="grid feat-grid">
      {features.map((feature, i) => (
        <article class="card feat reveal" style={`transition-delay:${i * 70}ms`}>
          <div class="icon-tile"><svg viewBox="0 0 24 24" fill="none" set:html={feature.icon} /></div>
          <h3>{feature.title}</h3>
          <p set:html={feature.description} />
        </article>
      ))}
    </div>
  </div>
</section>
<style>
.feat-section { position: relative; overflow: hidden; background:
    radial-gradient(60% 90% at 50% 0%, rgba(99,102,232,.18), transparent 70%),
    var(--color-navy-900); }
.feat-glow { position: absolute; z-index: 0; top: -8rem; left: 50%; transform: translateX(-50%); width: 60rem; max-width: 140%; aspect-ratio: 2/1; background: radial-gradient(ellipse at center, rgba(99,102,232,.14), transparent 70%); pointer-events: none; animation: driftA 16s ease-in-out infinite; }
.feat-section .container { position: relative; z-index: 1; }
.feat-grid { grid-template-columns: repeat(4, 1fr); }
.feat { position: relative; overflow: hidden; }
.feat .icon-tile { transition: transform .3s var(--ease-premium), box-shadow .3s ease; }
.feat:hover .icon-tile { transform: translateY(-3px) rotate(-5deg) scale(1.06); box-shadow: 0 18px 30px -12px rgba(90,70,200,.8); }
.feat h3 { margin: 1.4rem 0 .6rem; }
.feat p strong { color: var(--color-text); font-weight: 700; }
@media (max-width: 1040px) { .feat-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .feat-grid { grid-template-columns: 1fr; } }
</style>
