---
import SectionTitle from '../common/SectionTitle.astro';
const features = [
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 7v5l3.5 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
    title: 'Protocolo em até 48h',
    description: 'Seu pedido de registro no INPI pronto em <strong>dois dias úteis</strong>.'
  },
  {
    icon: '<path d="M12 3l1.8 4.9L18.7 9l-4.9 1.8L12 15l-1.8-4.2L5.3 9l4.9-1.1L12 3z" fill="currentColor"/><path d="M18.5 14.5l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7.7-1.8z" fill="currentColor"/>',
    title: 'Pesquisa com IA',
    description: 'Software de ponta para <strong>análise de colidência e viabilidade real</strong>.'
  },
  {
    icon: '<path d="M12 3l7 3v5c0 4.2-2.9 7.4-7 8.6C7.9 18.4 5 15.2 5 11V6l7-3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 11.5l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Garantia de novo pedido',
    description: 'Se o INPI negar, <strong>refazemos o processo sem custo adicional</strong>.'
  },
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M8.5 12.5l2.2 2.2 4.8-4.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Credenciada no INPI',
    description: 'Equipe capacitada, com <strong>88% de aprovação nos pedidos protocolados desde 2021</strong>.'
  }
];
---
<section class="section feat-section" id="empresa">
  <div class="feat-glow" aria-hidden="true"></div>
  <div class="container">
    <SectionTitle eyebrow="Por que Registrium" title="Registro de marca sem burocracia e com transparência" description="Desmitificamos o processo de registro e trazemos a segurança de uma equipe credenciada no INPI para empresas de todos os portes." />
    <div class="grid feat-grid">
      {features.map((feature, i) => (
        <article class="card feat reveal" style={`transition-delay:${i * 70}ms`}>
          <div class="icon-tile"><svg viewBox="0 0 24 24" fill="none" set:html={feature.icon} /></div>
          <h3>{feature.title}</h3>
          <p set:html={feature.description} />
        </article>
      ))}
    </div>
  </div>
</section>
<style>
.feat-section { position: relative; overflow: hidden; }
.feat-glow { position: absolute; z-index: 0; top: -8rem; left: 50%; transform: translateX(-50%); width: 60rem; max-width: 140%; aspect-ratio: 2/1; background: radial-gradient(ellipse at center, rgba(99,102,232,.06), transparent 70%); pointer-events: none; }
.feat-section .container { position: relative; z-index: 1; }
.feat-grid { grid-template-columns: repeat(4, 1fr); }
.feat h3 { margin: 1.4rem 0 .6rem; }
.feat p strong { color: var(--color-text); font-weight: 700; }
@media (max-width: 1040px) { .feat-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .feat-grid { grid-template-columns: 1fr; } }
</style>
