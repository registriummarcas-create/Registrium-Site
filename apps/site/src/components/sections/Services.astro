---
import SectionTitle from '../common/SectionTitle.astro';
import { services } from '../../data/services';
---
<section id="servicos" class="section section--soft">
  <div class="container">
    <SectionTitle eyebrow="Atuação" title="Serviços para proteger, defender e acompanhar a marca." />
    <div class="grid services-grid">
      {services.map((service) => <article class="card"><h3>{service.title}</h3><p>{service.description}</p></article>)}
    </div>
  </div>
</section>
<style>
.services-grid { grid-template-columns: repeat(3, 1fr); }
@media (max-width: 850px) { .services-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .services-grid { grid-template-columns: 1fr; } }
</style>
