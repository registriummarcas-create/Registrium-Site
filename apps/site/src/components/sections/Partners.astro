---
import SectionTitle from '../common/SectionTitle.astro';
import { contactConfig } from '../../config/contact';

const items = [
  {
    icon: '<path d="M12 3v18M6 21h12M12 6l6 3-2.5 4.5a3.8 3.8 0 01-7 0L6 9l6-3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Para contadores',
    description: 'Ofereça o registro de marca aos seus clientes de MEI, ME e EPP sem sair da sua rotina de atendimento.'
  },
  {
    icon: '<path d="M4 20l4-1 10-10-3-3L5 16l-1 4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>',
    title: 'Para designers',
    description: 'Depois de criar a marca, indique o registro no INPI e proteja o trabalho que você mesmo desenhou.'
  },
  {
    icon: '<path d="M12 2 3 6v6c0 5 4 8.5 9 10 5-1.5 9-5 9-10V6l-9-4Z" stroke="currentColor" stroke-width="1.6"/>',
    title: 'Como funciona',
    description: 'Cadastre-se abaixo, receba o material de indicação e acompanhe o status de cada cliente indicado.'
  }
];
---
<section class="section section--dark partners" id="parceiros">
  <div class="container">
    <SectionTitle eyebrow="Programa de parceiros" title="Contadores e designers: registrem marcas com a gente" description="Você já está perto de quem precisa proteger uma marca. Indique ou registre em parceria com a Registrium e ganhe comissão por indicação." />
    <div class="partners-grid reveal">
      <div class="partners-copy">
        {items.map((item) => (
          <div class="p-item">
            <div class="icon-tile gi" style="background:rgba(255,255,255,.08);color:#9fd3f2;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={item.icon} /></div>
            <div>
              <div class="pt">{item.title}</div>
              <div class="pd">{item.description}</div>
            </div>
          </div>
        ))}
      </div>
      <form class="partners-form" id="partnerForm" data-whatsapp-number={contactConfig.whatsappNumber} novalidate>
        <div class="form-grid">
          <div class="field"><label for="p-nome">Nome completo</label><input id="p-nome" name="nome" type="text" placeholder="Seu nome" required /></div>
          <div class="field">
            <label for="p-perfil">Você é</label>
            <select id="p-perfil" name="perfil" required>
              <option value="" disabled selected>Selecione</option>
              <option value="Contador(a)">Contador(a)</option>
              <option value="Designer">Designer</option>
              <option value="Outro parceiro">Outro parceiro</option>
            </select>
          </div>
          <div class="field"><label for="p-whats">WhatsApp</label><input id="p-whats" name="whats" type="tel" placeholder="(00) 00000-0000" required /></div>
          <div class="field"><label for="p-empresa">Escritório / estúdio</label><input id="p-empresa" name="empresa" type="text" placeholder="Nome do escritório ou estúdio" /></div>
          <div class="field full"><label for="p-msg">Mensagem (opcional)</label><textarea id="p-msg" name="msg" placeholder="Conte um pouco sobre seus clientes ou como quer parceirar"></textarea></div>
        </div>
        <div class="form-foot">
          <p class="form-note">Ao enviar, você será direcionado ao WhatsApp da Registrium com seus dados preenchidos.</p>
          <button type="submit" class="button button--primary">Quero ser parceiro</button>
        </div>
        <div class="form-ok" id="partnerOk">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Abrindo o WhatsApp com seus dados…
        </div>
      </form>
    </div>
  </div>
</section>
<script>
  const form = document.getElementById('partnerForm') as HTMLFormElement | null;
  if (form) {
    const whatsappNumber = form.dataset.whatsappNumber;
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const data = Object.fromEntries(new FormData(form).entries());
      let message = 'Olá! Quero ser parceiro da Registrium.\n\n';
      message += `Nome: ${data.nome}\nPerfil: ${data.perfil}\nWhatsApp: ${data.whats}`;
      if (data.empresa) message += `\nEscritório/estúdio: ${data.empresa}`;
      if (data.msg) message += `\nMensagem: ${data.msg}`;
      document.getElementById('partnerOk')?.classList.add('show');
      window.open(`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`, '_blank', 'noopener');
    });
  }
</script>
<style>
.partners-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: 2.75rem; align-items: center; max-width: 65rem; margin: 0 auto; }
.partners-copy .p-item { display: flex; gap: .875rem; margin-bottom: 1.125rem; }
.partners-copy .pt { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: .91rem; margin-bottom: .2rem; }
.partners-copy .pd { font-size: .81rem; color: var(--color-on-dark-soft); line-height: 1.5; }
.partners-form { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-md); padding: 2rem 1.875rem; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: .375rem; }
.field { display: flex; flex-direction: column; gap: .44rem; }
.field.full { grid-column: 1 / -1; }
.field label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .78rem; font-weight: 700; color: var(--color-white); }
.field input, .field select, .field textarea { font-family: 'Inter', sans-serif; font-size: .91rem; color: var(--color-white); background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.18); border-radius: .69rem; padding: .75rem .875rem; outline: none; transition: border-color .15s ease; }
.field input::placeholder, .field textarea::placeholder { color: #8b85ae; }
.field select option { color: #111; }
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(--color-blue); }
.field textarea { resize: vertical; min-height: 5.5rem; font-family: 'Inter', sans-serif; }
.form-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 1.375rem; flex-wrap: wrap; }
.form-note { font-size: .75rem; color: var(--color-on-dark-soft); max-width: 21rem; line-height: 1.5; margin: 0; }
.form-ok { display: none; align-items: center; gap: .625rem; background: #eaf6ef; border: 1px solid #bee3cb; color: #1f7a4d; border-radius: .75rem; padding: .75rem 1rem; font-size: .84rem; font-weight: 600; margin-top: 1rem; }
.form-ok.show { display: flex; }
@media (max-width: 920px) { .partners-grid { grid-template-columns: 1fr; gap: 2rem; } }
@media (max-width: 560px) { .form-grid { grid-template-columns: 1fr; } .partners-form { padding: 1.625rem 1.375rem; } .form-foot { flex-direction: column; align-items: stretch; } .form-foot .button { width: 100%; } }
</style>
