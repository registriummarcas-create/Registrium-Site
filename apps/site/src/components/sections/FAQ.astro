---
import SectionTitle from '../common/SectionTitle.astro';
import { faqItems } from '../../data/faq';
---
<section id="duvidas" class="section">
  <div class="container faq-wrap">
    <SectionTitle eyebrow="Perguntas frequentes" title="Informação clara antes da decisão." />
    <div>
      {faqItems.map((item) => (
        <details><summary>{item.question}</summary><p>{item.answer}</p></details>
      ))}
    </div>
  </div>
</section>
<style>
.faq-wrap { max-width: 58rem; }
details { border-top: 1px solid var(--color-border); padding: 1.25rem 0; }
details:last-child { border-bottom: 1px solid var(--color-border); }
summary { cursor: pointer; font-weight: 850; font-size: 1.1rem; }
details p { color: var(--color-muted); max-width: 48rem; }
</style>
