---
import SectionTitle from '../common/SectionTitle.astro';
const benefits = [
  ['Segurança para investir', 'Reduza o risco de construir valor sobre um nome que poderá ser contestado.'],
  ['Ativo empresarial', 'Uma marca registrada pode integrar o patrimônio e apoiar licenciamento, franquia e expansão.'],
  ['Estratégia por classes', 'A proteção é planejada segundo produtos, serviços e perspectivas de crescimento.'],
  ['Acompanhamento técnico', 'Publicações, prazos e decisões são acompanhados durante o processo administrativo.']
];
---
<section class="section">
  <div class="container">
    <SectionTitle eyebrow="Valor protegido" title="O registro não é uma formalidade isolada. É parte da estratégia do negócio." />
    <div class="grid benefit-grid">
      {benefits.map(([title, description]) => <article class="card"><h3>{title}</h3><p>{description}</p></article>)}
    </div>
  </div>
</section>
<style>
.benefit-grid { grid-template-columns: repeat(2, 1fr); }
@media (max-width: 650px) { .benefit-grid { grid-template-columns: 1fr; } }
</style>
