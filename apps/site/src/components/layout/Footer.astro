---
import { contactConfig } from '../../config/contact';
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <img src="/images/logo-full.png" alt="Registrium — Copyright e Marcas" />
      <p>Registro de marcas no INPI com transparência, tecnologia e preço publicado. Acompanhamento diário do início ao certificado.</p>
      <p class="cnpj">CNPJ: {contactConfig.cnpj}</p>
    </div>
    <div>
      <h4>Serviços</h4>
      <ul>
        <li><a href="/#simulador">Planos de registro</a></li>
        <li><a href="/#incluso">O que está incluso</a></li>
        <li><a href="/#servicos">Outros serviços</a></li>
      </ul>
    </div>
    <div>
      <h4>Empresa</h4>
      <ul>
        <li><a href="/#empresa">Por que Registrium</a></li>
        <li><a href="/#marcas">Marcas registradas</a></li>
        <li><a href="/#comparativo">Nosso diferencial</a></li>
        <li><a href="/parceiros">Programa de parceiros</a></li>
        <li><a href="/#faq">Perguntas frequentes</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>
    <div>
      <h4>Fale com a gente</h4>
      <ul>
        <li><a href="/#cadastro">Cadastro prévio</a></li>
        <li><a href={`https://wa.me/${contactConfig.whatsappNumber}`} target="_blank" rel="noreferrer">WhatsApp {contactConfig.phoneDisplay}</a></li>
        <li><a href={`mailto:${contactConfig.email}`}>{contactConfig.email}</a></li>
        <li><a href={contactConfig.instagramUrl} target="_blank" rel="noreferrer">{contactConfig.instagramHandle}</a></li>
        <li><a href="/politica-de-privacidade">Política de Privacidade</a></li>
        <li><a href="/termos-de-uso">Termos de Uso</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© 2026 Registrium Copyright e Marcas. Todos os direitos reservados.</span>
    <span class="badges">
      <span class="pb">
        <img src="/images/bandeira-paraiba.jpg" alt="Bandeira da Paraíba" width="20" height="14" />
        Empresa paraibana
      </span>
      <span class="inpi">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 2 3 6v6c0 5 4 8.5 9 10 5-1.5 9-5 9-10V6l-9-4Z" stroke="currentColor" stroke-width="1.8"/></svg>
        Empresa credenciada no INPI
      </span>
    </span>
  </div>
</footer>
<style>
.footer { position: relative; padding: 3.5rem 0 2.2rem; border-top: 1px solid var(--color-border); background: var(--color-white); }
.footer::before { content: ""; position: absolute; top: -1px; left: 0; right: 0; height: 3px; background: var(--grad-brand); }
.footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.1fr; gap: 2.5rem; }
.footer-about img { height: 2.5rem; width: auto; margin-bottom: 1rem; }
.footer-about p { font-size: .9rem; color: var(--color-muted); max-width: 19rem; line-height: 1.6; margin: 0; }
.footer-about .cnpj { font-size: .78rem; margin-top: .9rem; font-weight: 600; }
.footer-grid h4 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: .75rem; letter-spacing: .1em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 1rem; font-weight: 700; }
.footer-grid ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .7rem; }
.footer-grid a { font-size: .9rem; color: var(--color-muted); text-decoration: none; }
.footer-grid a:hover { color: var(--color-violet); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); font-size: .8rem; color: var(--color-muted); flex-wrap: wrap; gap: .75rem; }
.footer-bottom .badges { display: inline-flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
.footer-bottom .inpi, .footer-bottom .pb { display: inline-flex; align-items: center; gap: .5rem; }
.footer-bottom .inpi svg { color: var(--color-blue); }
.footer-bottom .pb img { width: 1.25rem; height: .875rem; object-fit: cover; border-radius: 2px; border: 1px solid var(--color-border); flex: none; }
@media (max-width: 900px) { .footer-grid { grid-template-columns: 1fr 1fr; row-gap: 2rem; } }
@media (max-width: 560px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
