---
import { contactConfig } from '../../config/contact';
import { buildWhatsAppUrl } from '../../lib/whatsapp';
const url = buildWhatsAppUrl(contactConfig.whatsappNumber, contactConfig.whatsappMessage);
---
<a class="floating" href={url} aria-label="Falar com a Registrium pelo WhatsApp" data-track="whatsapp_click" data-location="floating">
  <span aria-hidden="true">WA</span>
</a>
<style>
.floating { position: fixed; right: 1rem; bottom: 1rem; z-index: 30; width: 3.5rem; height: 3.5rem; border-radius: 50%; display: grid; place-items: center; text-decoration: none; font-weight: 900; background: var(--color-turmaline); color: var(--color-navy-950); box-shadow: var(--shadow-lg); border: 3px solid white; }
</style>
